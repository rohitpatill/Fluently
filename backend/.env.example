# --- LLM provider API keys (fill in the ones you have) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Model selection ---
# provider: openai | anthropic | google_genai
DEFAULT_PROVIDER=google_genai
DEFAULT_MODEL=gemini-3.1-flash-lite-preview
# Judge model scores word usage; can be a cheaper/faster model
JUDGE_PROVIDER=google_genai
JUDGE_MODEL=gemini-3.1-flash-lite-preview
# Utility model for topic suggestions / word enrichment
UTILITY_PROVIDER=google_genai
UTILITY_MODEL=gemini-3.1-flash-lite-preview

# --- Storage (MongoDB) ---
# Full SRV connection string INCLUDING the database name in the path (e.g. /fluently).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/fluently?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=fluently

# DATA_DIR still used for any transient local files (kept for compatibility)
DATA_DIR=./data

# --- Google OAuth ("Continue with Google") ---
# Create a Web-application OAuth 2.0 Client in Google Cloud Console.
# Authorized redirect URI must be: <OAUTH_REDIRECT_BASE>/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Public base URL of THIS backend. Prod: https://api.yourapp.com (also enables Secure cookies).
OAUTH_REDIRECT_BASE=http://localhost:8000
# Where users are redirected after login (the frontend origin). Prod: https://app.yourapp.com
FRONTEND_URL=http://localhost:5173
# Strong random secrets (e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`).
SESSION_SECRET=
STATE_COOKIE_SECRET=
# Session cookie lifetime in days (configurable; default 7).
SESSION_MAX_AGE_DAYS=7
