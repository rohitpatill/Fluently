# --- LLM provider API keys (fill in the ones you have) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Model selection ---
# provider: openai | anthropic | google_genai
DEFAULT_PROVIDER=google_genai
DEFAULT_MODEL=gemini-3.1-flash-lite-preview
# Judge model scores word usage; can be a cheaper/faster model
JUDGE_PROVIDER=google_genai
JUDGE_MODEL=gemini-3.1-flash-lite-preview
# Utility model for topic suggestions / word enrichment
UTILITY_PROVIDER=google_genai
UTILITY_MODEL=gemini-3.1-flash-lite-preview

# --- Storage (MongoDB) ---
# Full SRV connection string INCLUDING the database name in the path (e.g. /fluently).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/fluently?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=fluently

# DATA_DIR still used for any transient local files (kept for compatibility)
DATA_DIR=./data
