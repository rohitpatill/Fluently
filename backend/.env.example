# --- LLM provider API keys (fill in the ones you have) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Model selection ---
# provider: openai | anthropic | google_genai
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-5
# Judge model scores word usage; can be a cheaper/faster model
JUDGE_PROVIDER=anthropic
JUDGE_MODEL=claude-haiku-4-5-20251001
# Utility model for topic suggestions / word enrichment
UTILITY_PROVIDER=anthropic
UTILITY_MODEL=claude-haiku-4-5-20251001

# --- Storage ---
DATABASE_URL=sqlite:///./data/eng.db
DATA_DIR=./data
